generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Task {
  id                String   @id @default(cuid())
  title             String
  status            String
  selectedPlatforms Json
  input             Json
  contents          Json
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model AppSettings {
  id        String   @id
  settings  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
